# Terraform local state — never committed. HCP holds the real state.
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# Terraform plan output
*.tfplan
crash.log
crash.*.log

# Sensitive tfvars — values that should not be committed
*.tfvars.secret
*.auto.tfvars.secret
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Editor + OS
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# Local logs
*.log

# Lambda deployment packages (built on HCP / CI)
**/lambda/node_modules/
modules/lambda-http-api/.build/

# Planning files used during active work are committed; uncomment if you'd rather not
# task_plan.md
# findings.md
# progress.md
