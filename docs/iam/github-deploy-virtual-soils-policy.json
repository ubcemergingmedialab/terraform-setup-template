{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DeploySiteBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:GetObject"
      ],
      "Resource": [
        "arn:aws:s3:::ubc-eml-virtual-soils-prod-site-*",
        "arn:aws:s3:::ubc-eml-virtual-soils-prod-site-*/*"
      ]
    },
    {
      "Sid": "InvalidateCloudFront",
      "Effect": "Allow",
      "Action": "cloudfront:CreateInvalidation",
      "Resource": "arn:aws:cloudfront::940309384764:distribution/*"
    },
    {
      "Sid": "ReadDistributionForDeploy",
      "Effect": "Allow",
      "Action": [
        "cloudfront:GetDistribution",
        "cloudfront:ListDistributions"
      ],
      "Resource": "*"
    }
  ]
}
